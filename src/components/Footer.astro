---
const year = new Date().getFullYear();
---

<footer class="site-footer" data-overscroll-theme="#1a1a1a">
  <div class="site-footer-inner container">
    <p class="site-footer-block site-footer-block--left">
      <span>Franck Chabin</span>
      <span>Graphiste et directeur artistique</span>
    </p>

    <p class="site-footer-block site-footer-block--center">
      <span>Paris, France</span>
      <span>&copy;{year}</span>
    </p>

    <div class="site-footer-block site-footer-block--right">
      <span>Contact</span>
      <a href="mailto:franck.chabin@icloud.com">franck.chabin@icloud.com</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .site-footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xl);
    padding-top: clamp(2.1rem, 4vw, 3.1rem);
    padding-bottom: clamp(2.1rem, 4vw, 3.1rem);
  }

  .site-footer-block {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.24rem;
    color: var(--color-bg);
    font-family: var(--font-nav);
    font-size: clamp(0.78rem, 1.25vw, 1.42rem);
    line-height: 1.04;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    text-align: center;
    min-width: 0;
  }

  .site-footer-block--center {
    text-align: center;
  }

  .site-footer-block--right {
    align-items: center;
  }

  .site-footer-block a {
    color: inherit;
    width: fit-content;
  }

  @media (hover: hover) {
    .site-footer-block a {
      transition: opacity var(--transition-fast);
    }

    .site-footer-block a:hover {
      opacity: 0.7;
    }
  }

  @media (min-width: 768px) {
    .site-footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: start;
      gap: clamp(1rem, 2vw, var(--space-xl));
    }

    .site-footer-block {
      flex: 1 1 0;
      white-space: nowrap;
    }

    .site-footer-block--left {
      align-items: flex-start;
      text-align: left;
    }

    .site-footer-block--center {
      align-items: flex-end;
      text-align: right;
    }

    .site-footer-block--right {
      align-items: flex-end;
      text-align: right;
    }
  }
</style>
