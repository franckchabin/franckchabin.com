---
const year = new Date().getFullYear();
---

<footer class="site-footer" data-overscroll-theme="#1a1a1a">
  <div class="site-footer-line-wrap container" aria-hidden="true"><div class="site-footer-line"></div></div>
  <div class="site-footer-inner container">
    <div class="site-footer-block site-footer-block--identity">
      <span>Franck Chabin</span>
      <span>Graphiste et directeur artistique</span>
    </div>

    <div class="site-footer-block site-footer-block--meta">
      <span>Paris, France — &copy;{year}</span>
    </div>

    <div class="site-footer-block site-footer-block--contact">
      <span>Contact</span>
      <a href="mailto:franck.chabin@icloud.com">franck.chabin@icloud.com</a>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-text);
    color: var(--color-bg);
    padding-top: var(--space-xl);
  }

  .site-footer-line-wrap {
    padding: 0 var(--gutter);
  }

  .site-footer-line {
    height: 1px;
    background-color: rgba(255, 255, 255, 0.2);
    margin-bottom: var(--space-xl);
  }

  .site-footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .site-footer-block {
    display: flex;
    flex-direction: column;
    font-family: var(--font-nav);
    color: var(--color-bg);
    opacity: 0.2;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.35;
  }

  .site-footer-block a {
    color: inherit;
    width: fit-content;
  }

  @media (hover: hover) {
    .site-footer-block a {
      transition: opacity var(--transition-fast);
    }
    .site-footer-block a:hover {
      opacity: 1;
    }
  }

  /* =============================================
     MOBILE — tout centré, empilé proprement
     ============================================= */
  .site-footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    padding: 0 var(--gutter) var(--space-lg);
  }

  .site-footer-block {
    align-items: center;
    gap: 0.15em;
    font-size: clamp(0.7rem, 2.8vw, 0.85rem);
  }

  /* =============================================
     DESKTOP — 3 colonnes classiques
     ============================================= */
  @media (min-width: 768px) {
    .site-footer-inner {
      flex-direction: row;
      justify-content: space-between;
      align-items: start;
      text-align: left;
      gap: var(--space-xl);
    }

    .site-footer-block {
      flex: 1 1 0;
      white-space: nowrap;
      font-size: clamp(0.75rem, 1.25vw, 1.15rem);
      line-height: 1.1;
      gap: var(--space-xs);
    }

    .site-footer-block--identity {
      align-items: flex-start;
    }

    .site-footer-block--meta {
      align-items: center;
    }

    .site-footer-block--contact {
      align-items: flex-end;
      text-align: right;
    }
  }
</style>
