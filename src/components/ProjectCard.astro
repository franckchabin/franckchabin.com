---
import { BASE } from '../config';
/*
  Carte projet — grille homepage
  Aucun effet de hover, zoom, ou halo.
  Les tags sont passifs (classe .tag).
*/

interface Props {
  title: string;
  slug: string;
  tags: string[];
  image?: string;
  video?: string;
}

const { title, slug, tags, image, video } = Astro.props;
---

<a href={`${BASE}${slug}`} class="project-card">
  <div class="project-card-media">
    {video ? (
      <video data-src={video} autoplay loop muted playsinline preload="none" class="project-card-visual" />
    ) : image ? (
      <img src={image} alt={`Projet ${title}`} loading="lazy" class="project-card-visual" />
    ) : null}
  </div>

  <div class="project-card-info">
    <h3 class="project-card-title">{title}</h3>
    <div class="project-card-tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </div>
</a>

<style>
  .project-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .project-card-media {
    width: 100%;
  }

  .project-card-visual {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-card-info {
    display: flex;
    align-items: flex-end;       /* titre et tags alignés en bas */
    justify-content: space-between; /* titre à gauche, tags à droite */
    gap: 0.5rem;
    padding-top: 0.75rem;
    flex-wrap: wrap;
  }

  .project-card-title {
    font-family: var(--font-serif);
    font-size: clamp(1.15rem, 1.8vw, 1.5rem);
    font-weight: normal;
    font-style: normal;
    line-height: 1.25;
    flex: 1;
    min-width: 0;
  }

  .project-card-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    flex-shrink: 0;
  }

  /* Taille tag augmentée — lisible à côté du titre */
  .project-card-tags .tag {
    font-size: 0.8rem;
  }
</style>
