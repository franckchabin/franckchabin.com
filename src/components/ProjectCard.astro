---
import { BASE } from '../config';
/*
  Carte projet — grille homepage
  Aucun effet de hover, zoom, ou halo.
  Les tags sont passifs (classe .tag).
*/

interface Props {
  title: string;
  slug: string;
  tags: string[];
  image?: string;
  video?: string;
}

const { title, slug, tags, image, video } = Astro.props;
---

<a href={`${BASE}${slug}`} class="project-card">
  <div class="project-card-media">
    {video ? (
      <video data-src={video} autoplay loop muted playsinline preload="none" class="project-card-visual" />
    ) : image ? (
      <img src={image} alt={`Projet ${title}`} loading="lazy" class="project-card-visual" />
    ) : null}
  </div>

  <div class="project-card-info">
    <h3 class="project-card-title">{title}</h3>
    <div class="project-card-tags">
      {tags.map(tag => <span class="tag">{tag}</span>)}
    </div>
  </div>
</a>

<style>
  .project-card {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .project-card-media {
    width: 100%;
  }

  .project-card-visual {
    width: 100%;
    height: auto;
    display: block;
  }

  /* Mobile : titre au-dessus, tags en-dessous ferrés à droite */
  .project-card-info {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding-top: 0.75rem;
  }

  .project-card-title {
    font-family: var(--font-serif);
    font-size: clamp(1.8rem, 2.5vw, 2.2rem);
    font-weight: normal;
    font-style: normal;
    line-height: 1.1;
  }

  .project-card-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: flex-end; /* ferré à droite */
  }

  .project-card-tags .tag {
    font-size: 0.8rem;
  }

  /* Desktop : titre à gauche, tags à droite sur la même ligne */
  @media (min-width: 768px) {
    .project-card-info {
      flex-direction: row;
      align-items: flex-end;
    }

    .project-card-title {
      flex: 1;
      min-width: 0;
    }

    .project-card-tags {
      justify-content: flex-start;
      flex-shrink: 0;
    }
  }
</style>
