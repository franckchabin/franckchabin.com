---
import { BASE } from '../config';
/*
  Layout de base — enveloppe toutes les pages
  Inclut : <head>, polices, styles globaux, navigation

  Props :
  - title : titre de la page (apparaît dans l'onglet du navigateur)
  - description : description pour le SEO
*/

import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  loadGsap?: boolean; // charger GSAP uniquement sur les pages qui en ont besoin
}

const {
  title,
  description = "Franck Chabin — Créatif indépendant basé à Paris. Direction artistique, objets d'édition, identités visuelles, dessin de caractères, interfaces web.",
  loadGsap = false,
} = Astro.props;
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />

  <!-- SEO -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />

  <!-- Préchargement police custom (évite le flash FOUT) -->
  <link rel="preload" as="font" type="font/woff" href={`${BASE}fonts/maria-unconnected.woff`} crossorigin />

  <!-- Connexion anticipée au CDN vidéo Cloudinary -->
  <link rel="preconnect" href="https://res.cloudinary.com" crossorigin />
  <link rel="dns-prefetch" href="https://res.cloudinary.com" />

  <!-- Polices Google Fonts — display=block évite le flash de substitution -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter+Tight:wght@300;400;500;600;700&display=block"
    rel="stylesheet"
  />

  <!-- GSAP — uniquement sur les pages qui en ont besoin (ex: homepage) -->
  {loadGsap && <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js" defer></script>}

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />

  <title>{title}</title>
  <Fragment set:html={`<style>@font-face{font-family:'Maria Unconnected';src:url('${BASE}fonts/maria-unconnected.woff') format('woff');font-weight:normal;font-style:normal;font-display:block;}</style>`} />
</head>
<body>
  <Nav />
  <main>
    <slot />
  </main>
  <Footer />
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const videos = Array.from(document.querySelectorAll('video[data-src]')) as HTMLVideoElement[];

      if (videos.length) {
        // Génère un poster Cloudinary pour les vidéos qui n'en ont pas
        videos.forEach(v => {
          if (!v.poster && v.dataset.src) {
            v.poster = v.dataset.src.replace(/\.mp4$/, '.jpg');
          }
        });

        const io = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              const v = e.target as HTMLVideoElement;
              if (v.dataset.src) {
                v.src = v.dataset.src;
                v.load();
                v.play().catch(() => {});
              }
              io.unobserve(v);
            }
          });
        }, { rootMargin: '400px 0px', threshold: 0 });

        videos.forEach(v => io.observe(v));
      }

      // Fade-in au scroll pour images et vidéos dans les galeries/grilles
      const fadeTargets = Array.from(
        document.querySelectorAll<HTMLElement>(
          '.project-card-visual, .project-gallery > img, .project-gallery > video, .project-gallery > .gallery-bg, .project-gallery > .gallery-row img'
        )
      );

      if (fadeTargets.length) {
        fadeTargets.forEach(el => el.classList.add('fade-in-media'));

        const fadeObserver = new IntersectionObserver((entries) => {
          entries.forEach(e => {
            if (e.isIntersecting) {
              (e.target as HTMLElement).classList.add('is-visible');
              fadeObserver.unobserve(e.target);
            }
          });
        }, { rootMargin: '200px 0px', threshold: 0 });

        fadeTargets.forEach(el => fadeObserver.observe(el));
      }

      const overscrollTargets = Array.from(document.querySelectorAll<HTMLElement>('[data-overscroll-theme]'));

      if (overscrollTargets.length) {
        const syncOverscrollTheme = () => {
          const viewportHeight = window.innerHeight;
          let activeTheme = '';

          for (let i = overscrollTargets.length - 1; i >= 0; i -= 1) {
            const target = overscrollTargets[i];
            const rect = target.getBoundingClientRect();

            if (rect.bottom > 0 && rect.top < viewportHeight) {
              activeTheme = target.dataset.overscrollTheme ?? '';
              break;
            }
          }

          document.documentElement.style.backgroundColor = activeTheme;
        };

        const themeObserver = new IntersectionObserver(syncOverscrollTheme, { threshold: 0 });

        overscrollTargets.forEach(target => themeObserver.observe(target));
        window.addEventListener('resize', syncOverscrollTheme, { passive: true });
        syncOverscrollTheme();
      }
    });
  </script>
</body>
</html>
