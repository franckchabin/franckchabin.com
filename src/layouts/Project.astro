---
/*
  LAYOUT PROJET
  Structure calquée sur le site Webflow de référence :
  1. Titre (h1, pleine largeur)
  2. Séparateur horizontal
  3. Deux colonnes : gauche (sideInfo) / droite (description + tags)
  4. Galerie — décalée à droite pour s'aligner avec la colonne description
  5. "Projet suivant" — bouton .btn pill en bas à gauche
*/

import Base from './Base.astro';
import { BASE } from '../config';

interface Props {
  title: string;
  description: string;
  tags: string[];
  sideInfo?: string;
  nextProject?: {
    title: string;
    slug: string;
  };
}

const { title, description, tags, sideInfo, nextProject } = Astro.props;
---

<Base title={`${title} — Franck Chabin`} description={description}>
  <article class="project">

    <!-- Titre -->
    <header class="project-header container">
      <h1 class="project-title">{title}</h1>
    </header>

    <!-- Séparateur -->
    <div class="project-separator container-full"></div>

    <!-- Description + infos latérales -->
    <section class="project-intro container">
      <aside class="project-side-info">
        {sideInfo
          ? <Fragment set:html={sideInfo} />
          : <span></span>
        }
      </aside>
      <div class="project-description">
        <p>{description}</p>
        <div class="project-tags">
          {tags.map(tag => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- Galerie : décalée à droite (aligne avec la colonne description) -->
    <section class="project-gallery container">
      <slot />
    </section>

    <!-- Navigation projet suivant -->
    {nextProject && (
      <nav class="project-next container" aria-label="Projet suivant">
        <a href={`${BASE}${nextProject.slug}`} class="btn project-next-btn">
          Projet suivant → {nextProject.title}
        </a>
      </nav>
    )}

  </article>
</Base>

<style>
  .project {
    padding-bottom: var(--space-2xl);
  }

  /* --- Titre --- */
  .project-header {
    padding-top: calc(var(--nav-height) + var(--space-sm));
    padding-bottom: var(--space-md);
  }

  .project-title {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 10vw, 8rem);
    line-height: 1;
    letter-spacing: -0.03em;
  }

  /* --- Séparateur pleine largeur --- */
  .container-full {
    width: 100%;
    padding: 0 var(--gutter);
  }

  .project-separator {
    height: 1px;
    background-color: var(--color-border);
    border: none;
    margin: 0;
  }

  /* --- Intro : deux colonnes --- */
  .project-intro {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-md);
    padding-top: var(--space-md);
    padding-bottom: var(--space-lg);
  }

  .project-side-info {
    font-family: var(--font-body);
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--color-text-light);
  }

  .project-description p {
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    line-height: 1.7;
    hyphens: auto;
    -webkit-hyphens: auto;
  }

  .project-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: var(--space-md);
  }

  /* --- Galerie --- */
  .project-gallery {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .project-gallery :global(img),
  .project-gallery :global(video) {
    width: 100%;
    height: auto;
    border-radius: var(--radius-card);
    display: block;
  }

  .project-gallery :global(.gallery-row) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-md);
  }

  .project-gallery :global(.gallery-bg) {
    padding: var(--space-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-card);
  }

  /* --- Projet suivant --- */
  .project-next {
    margin-top: var(--space-2xl);
  }

  .project-next-btn {
    display: inline-block;
  }

  /* =============================================
     DESKTOP : grille 2 colonnes
     ============================================= */
  @media (min-width: 768px) {
    .project-header {
      padding-bottom: var(--space-lg);
    }

    .project-intro {
      grid-template-columns: 250px 1fr;
      gap: var(--space-xl);
      padding-top: var(--space-lg);
    }

    /* Galerie décalée — s'aligne avec la colonne droite */
    .project-gallery {
      padding-left: calc(250px + var(--space-xl));
    }

    /* Projet suivant — bas gauche, aligné avec le titre */
  }

  @media (min-width: 1024px) {
    .project-header {
      /* On garde le calcul nav-height partout — la nav est fixe à tous les breakpoints */
      padding-top: calc(var(--nav-height) + var(--space-md));
    }
  }
</style>
