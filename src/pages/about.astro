---
import { BASE } from '../config';
/*
  PAGE À PROPOS
  Recomposition de la page d'après la maquette :
  - introduction centrée
  - bloc contact centré
  - liens sociaux
  - expertises / logiciels
  - signature en bas de page
*/

import Base from '../layouts/Base.astro';

const services = [
  'Motion design',
  "Objets d'édition",
  'Identités visuelles',
  'Dessin de caractères',
  "Conception d'interfaces Web",
  'Direction artistique 360',
];

const software = [
  'Photoshop',
  'Illustrator',
  'InDesign',
  'Figma',
  'Webflow',
  'After Effect',
  'Premiere Pro',
  'Glyphs 3',
  'Cinema 4D',
  'Octane Render',
];
---

<Base title="À propos — Franck Chabin">
  <section class="about">
    <div class="container">
      <div class="about-shell">
        <div class="about-intro">
          <p>Je m&apos;appelle Franck, créatif indépendant basé à Paris, et grand amateur de pizzas.</p>
          <p>Inspiré par les objets imprimés autant que par la culture numérique, j&apos;aime naviguer entre ces deux univers pour voir comment ils peuvent se compléter naturellement.</p>
          <p>Je travaille sur des projets variés, de l&apos;identité visuelle à l&apos;édition en passant par le digital et le motion, avec une approche simple : m&apos;adapter rapidement, comprendre les enjeux et proposer des réponses justes, toujours avec une vraie attention aux détails.</p>
        </div>

        <div class="about-contact">
          <h2 class="about-heading about-heading--contact">On travaille ensemble ?</h2>
          <a href="mailto:franck.chabin@icloud.com" class="btn about-email">
            franck.chabin@icloud.com
          </a>
        </div>

        <div class="about-links" aria-label="Liens externes">
          <a href="https://www.linkedin.com/in/franckchabin/" target="_blank" rel="noopener noreferrer" class="btn">LinkedIn</a>
          <a href={`${BASE}cv.pdf`} target="_blank" rel="noopener noreferrer" class="btn">CV</a>
          <a href="https://www.behance.net/franckchabin" target="_blank" rel="noopener noreferrer" class="btn">Behance</a>
        </div>

        <div class="about-columns">
          <div class="about-column">
            <h2 class="about-heading">Expertises</h2>
            <div class="about-tags">
              {services.map(s => <span class="tag">{s}</span>)}
            </div>
          </div>

          <div class="about-column">
            <h2 class="about-heading">Compétences logicielles</h2>
            <div class="about-tags">
              {software.map(s => <span class="tag">{s}</span>)}
            </div>
          </div>
        </div>
 
        <p class="about-signoff">
          Raconter une histoire par la couleur et la forme pour faire sourire les yeux de son public.
        </p>
      </div>
    </div>
  </section>
</Base>

<style>
  .about {
    padding: calc(var(--nav-height) + var(--space-lg)) 0 var(--space-2xl);
  }

  .about-shell {
    width: min(100%, 900px);
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .about-intro {
    width: min(100%, 720px);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .about-intro p,
  .about-heading,
  .about-signoff {
    font-family: var(--font-serif);
    font-size: clamp(1.1rem, 4vw, 1.9rem);
    font-weight: normal;
    line-height: 1.3;
    hyphens: none;
    -webkit-hyphens: none;
    text-wrap: balance;
  }

  .about-intro p {
    max-width: 52ch;
    margin: 0 auto;
  }

  .about-contact {
    margin-top: var(--space-2xl);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .about-heading {
    font-style: italic;
  }

  .about-heading--contact {
    margin: 0;
  }

  .about-links,
  .about-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .about-links {
    margin-top: var(--space-2xl);
  }

  .about-columns {
    width: min(100%, 820px);
    margin-top: var(--space-2xl);
    display: grid;
    grid-template-columns: repeat(2, minmax(280px, 1fr));
    gap: var(--space-2xl);
  }

  .about-column {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-md);
  }

  .about-tags {
    max-width: 360px;
  }

  .about-signoff {
    width: min(100%, 460px);
    margin-top: var(--space-2xl);
    font-style: italic;
  }

  @media (min-width: 768px) {
    .about-intro p,
    .about-heading,
    .about-signoff {
      font-size: clamp(1.35rem, 2.2vw, 1.9rem);
      line-height: 1.35;
    }
  }

  @media (max-width: 767px) {
    .about {
      padding: calc(var(--nav-height) + var(--space-md)) 0 var(--space-2xl);
    }

    .about-shell {
      width: min(100%, 440px);
    }

    .about-intro {
      width: min(100%, 380px);
    }

    .about-intro p {
      max-width: 30ch;
    }

    .about-links {
      max-width: 320px;
    }

    .about-columns {
      width: min(100%, 360px);
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .about-signoff {
      width: min(100%, 320px);
    }
  }
</style>
