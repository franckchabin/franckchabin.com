---
import { BASE } from '../config';
/*
  PAGE PROJET : Anemo
  Conception d'interface et 3D pour une application météo.
*/
import Project from '../layouts/Project.astro';
---

<Project
  title="Anemo"
  description="Anemo est un projet de conception d'interface pour une application météo. Le design mêle visualisation de données en temps réel et rendus 3D pour offrir une expérience immersive et intuitive."
  tags={["Conception d'interface", "3D"]}
  nextProject={{ title: "Mémoire", slug: "typographes-createurs-de-caracteres-et-typodiversite" }}
>

  <!-- Vidéo principale (présentation de l'app) -->
  <video
    src="https://res.cloudinary.com/db5vnijzw/video/upload/v1719967321/%C2%A9franckchabin_Anemo_01_1280.mp4"
    autoplay loop muted playsinline
  ></video>

  <img src={`${BASE}images/projects/anemo/©franckchabin_ANEMO_02.webp`} alt="Anemo — écran d'accueil" loading="lazy" />

  <img src={`${BASE}images/projects/anemo/©franckchabin_ANEMO_03.webp`} alt="Anemo — détail interface" loading="lazy" />

  <!-- Vidéo interaction -->
  <video
    src="https://res.cloudinary.com/db5vnijzw/video/upload/v1719171662/%C2%A9franckchabin_ANEMO_04.mp4"
    autoplay loop muted playsinline
  ></video>

  <img src={`${BASE}images/projects/anemo/©franckchabin_ANEMO_05.webp`} alt="Anemo — vue météo" loading="lazy" />

  <img src={`${BASE}images/projects/anemo/©franckchabin_ANEMO_06.webp`} alt="Anemo — rendu 3D" loading="lazy" />

  <img src={`${BASE}images/projects/anemo/©franckchabin_ANEMO_07.webp`} alt="Anemo — composants UI" loading="lazy" />

  <!-- Vidéo animation -->
  <video
    src="https://res.cloudinary.com/db5vnijzw/video/upload/v1719171662/%C2%A9franckchabin_ANEMO_08.mp4"
    autoplay loop muted playsinline
  ></video>

  <img src={`${BASE}images/projects/anemo/©franckchabin_ANEMO_09.webp`} alt="Anemo — écran complet" loading="lazy" />

  <div class="gallery-row">
    <img src={`${BASE}images/projects/anemo/©franckchabin_ANEMO_10.webp`} alt="Anemo — détail 1" loading="lazy" />
    <img src={`${BASE}images/projects/anemo/©franckchabin_ANEMO_11.webp`} alt="Anemo — détail 2" loading="lazy" />
  </div>

</Project>
