---
import { BASE } from '../config';
/*
  PAGE PROJET : Fisheye
  Direction artistique et motion design pour le Prix Fisheye.
*/
import Project from '../layouts/Project.astro';
---

<Project
  title="Fisheye"
  description="Fisheye est un média d'avant-garde devenu référence en matière de photographie contemporaine. Pendant un an, j'y ai travaillé sur divers projets marquants comme la direction artistique et la promotion du Prix Fisheye de la Création Visuelle, l'exposition immersive Habeas Corpus et la mise en page des numéros 56 à 58 du magazine. J'ai également renforcé la présence numérique du média avec la création de teasers et autres visuels sur les réseaux sociaux."
  tags={["Objet éditorial", "Direction artistique", "Motion Design"]}
  sideInfo="<strong>En équipe avec :</strong><br/><br/>Julia Von Dorpp<br/>Lisa Cadot<br/>Bastien Forato<br/>Lisa Millot<br/>Valentin Socha"
  nextProject={{ title: "Anemo", slug: "anemo", thumbnail: "images/projects/anemo/©franckchabin_ANEMO_02.webp" }}
>

  <!-- Vidéo showreel (avec controls, pas autoplay) -->
  <video
    preload="auto"
    controls
    playsinline
    poster={`${BASE}images/projects/fisheye/©franckchabin_Fisheye_01_poster.webp`}
    style="width:100%; display:block;"
  >
    <source src="https://res.cloudinary.com/dqjhw8zd6/video/upload/v1720743025/%C2%A9franckchabin_Fisheye_showreel.mp4" type="video/mp4" />
  </video>

  <img src={`${BASE}images/projects/fisheye/©franckchabin_Fisheye_02.webp`} alt="Fisheye — déclinaison visuelle" loading="lazy" />

  <!-- Vidéo motion (avec controls, pas autoplay) -->
  <video
    preload="auto"
    controls
    playsinline
    poster="https://res.cloudinary.com/db5vnijzw/video/upload/v1720753437/%C2%A9franckchabin_Fisheye_03.jpg"
    style="width:100%; display:block;"
  >
    <source src="https://res.cloudinary.com/db5vnijzw/video/upload/v1720753437/%C2%A9franckchabin_Fisheye_03.mp4" type="video/mp4" />
  </video>

  <img src={`${BASE}images/projects/fisheye/©franckchabin_Fisheye_04.gif`} alt="Fisheye — animation" loading="lazy" />

  <img src={`${BASE}images/projects/fisheye/©franckchabin_Fisheye_05.webp`} alt="Fisheye — application" loading="lazy" />

</Project>
