---
import { BASE } from '../config';
/*
  PAGE PROJET : Golosino
  Identité visuelle pour une marque de pizza, générée avec l'IA.
*/
import Project from '../layouts/Project.astro';
---

<Project
  title="Golosino"
  description="Golosino est une identité visuelle créée pour une marque de pizza artisanale. Le projet explore les possibilités de l'intelligence artificielle dans la création d'identités graphiques, en combinant typographie expressive et imagerie générée."
  tags={["Identité visuelle", "IA"]}
  nextProject={{ title: "Ticket Culture", slug: "tiket-culture" }}
>

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_01.webp`} alt="Golosino — identité visuelle" loading="lazy" />

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_02.gif`} alt="Golosino — animation logo" loading="lazy" />

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_03.webp`} alt="Golosino — packaging pizza" loading="lazy" />

  <div class="gallery-row">
    <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_04.webp`} alt="Golosino — déclinaison 1" loading="lazy" />
    <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_05.webp`} alt="Golosino — déclinaison 2" loading="lazy" />
  </div>

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_06.webp`} alt="Golosino — mise en situation" loading="lazy" />

  <div class="gallery-row">
    <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_07.webp`} alt="Golosino — détail 1" loading="lazy" />
    <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_08.webp`} alt="Golosino — détail 2" loading="lazy" />
  </div>

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_09.webp`} alt="Golosino — vue d'ensemble" loading="lazy" />

  <div class="gallery-row">
    <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_10.webp`} alt="Golosino — déclinaison 3" loading="lazy" />
    <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_11.webp`} alt="Golosino — déclinaison 4" loading="lazy" />
  </div>

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_12.webp`} alt="Golosino — application" loading="lazy" />

  <div class="gallery-row">
    <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_13.webp`} alt="Golosino — détail 3" loading="lazy" />
    <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_14.webp`} alt="Golosino — détail 4" loading="lazy" />
  </div>

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_15.webp`} alt="Golosino — finale" loading="lazy" />

</Project>
