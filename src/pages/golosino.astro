---
import { BASE } from '../config';
/*
  PAGE PROJET : Golosino
  Identité visuelle pour une marque de pizza, générée avec l'IA.
*/
import Project from '../layouts/Project.astro';
---

<Project
  title="Golosino"
  description="Golosino, ma pizzeria traditionnelle de cœur à emporter est située dans le quartier Mouffetard. Elle propose une expérience culinaire authentique avec des ingrédients italiens frais et de qualité, préparés avec amour. Son logo moustachu et son style iconographique chaleureux rappellent les magnets de frigos, mettant en avant la qualité de ses ingrédients. Idéale pour les gourmands et les petits gloutons."
  tags={["Identité visuelle", "I.A"]}
  ogImage="images/opengraph/©franckchabin_Golosino_Open-Graph.webp"
  sideInfo="<strong>Polices de caractères :</strong><br/><br/>Aeonik par CoType Foundry<br/>Knocky par Jehoo Creative<br/><br/>Mockups par Bendito Mockup<br/>Photos avec Midjourney"
  nextProject={{ title: "Tiket Culture", slug: "tiket-culture", thumbnail: "images/projects/ticket-culture/©franckchabin_tiket-culture_Thumbnail.webp" }}
>

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_01.webp`} alt="Golosino — identité visuelle" loading="lazy" />

  <img src={`${BASE}images/projects/golosino/©franckchabin_GOLOSINO_02.gif`} alt="Golosino — animation logo" loading="lazy" />

