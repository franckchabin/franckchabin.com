---
import { BASE } from '../config';
/*
  PAGE PROJET : Tiket Culture
  Objet éditorial — jeu de tickets culturels pour le métro parisien.
*/
import Project from '../layouts/Project.astro';
---

<Project
  title="Ticket Culture"
  description="Ticket Culture est un objet éditorial qui réinvente les tickets de métro parisien en les transformant en supports culturels. Chaque ticket invite à découvrir un lieu culturel proche de la station, mêlant iconographie originale et rédaction soignée."
  tags={["Object éditorial", "Iconographie", "Rédaction"]}
  nextProject={{ title: "Fisheye", slug: "fisheye" }}
>

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_01_centre-pompidou-book-2.webp`} alt="Ticket Culture — livre Centre Pompidou" loading="lazy" />

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_02_all-asset.webp`} alt="Ticket Culture — ensemble des éléments" loading="lazy" />

  <!-- Vidéo teaser -->
  <video
    data-src="https://res.cloudinary.com/db5vnijzw/video/upload/v1720149503/%C2%A9franckchabin_tiket-culture_03_video_teaser.mp4"
    autoplay loop muted playsinline preload="none"
  ></video>

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_04_books-and-traveler.webp`} alt="Ticket Culture — livres et voyageur" loading="lazy" />

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_05_cultural-subway-adventure.webp`} alt="Ticket Culture — aventure culturelle métro" loading="lazy" />

  <!-- Vidéo pages -->
  <video
    data-src="https://res.cloudinary.com/db5vnijzw/video/upload/v1720149502/mkttoj9bmnyg63snepml.mp4"
    autoplay loop muted playsinline preload="none"
  ></video>

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_08_Pages-visual.webp`} alt="Ticket Culture — pages visuelles" loading="lazy" />

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_09_all-tickets.webp`} alt="Ticket Culture — tous les tickets" loading="lazy" />

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_10_all-icon.gif`} alt="Ticket Culture — animation icônes" loading="lazy" />

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_11_ticket-ligne-4.webp`} alt="Ticket Culture — ticket ligne 4" loading="lazy" />

  <div class="gallery-row">
    <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_13_bookmark-and-postcards.webp`} alt="Ticket Culture — marque-pages et cartes postales" loading="lazy" />
    <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_14_close-up-books.webp`} alt="Ticket Culture — gros plan livres" loading="lazy" />
  </div>

  <img src={`${BASE}images/projects/ticket-culture/©franckchabin_tiket-culture_15_logo.webp`} alt="Ticket Culture — logo" loading="lazy" />

</Project>
