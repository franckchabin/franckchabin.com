>

  <!-- Vidéo de présentation -->
  <video
    data-src="https://res.cloudinary.com/dqjhw8zd6/video/upload/v1720744642/%C2%A9franckchabin_TCCT_01-2.mp4"
    autoplay loop muted playsinline preload="none"
  ></video>

  <img src={`${import.meta.env.BASE_URL}images/projects/memoire/©franckchabin_TCCT_02.webp`} alt="Mémoire — couverture" loading="lazy" />

  <img src={`${import.meta.env.BASE_URL}images/projects/memoire/©franckchabin_TCCT_03.webp`} alt="Mémoire — pages intérieures" loading="lazy" />

