  <div class="gallery-row">
    <img src={`${import.meta.env.BASE_URL}images/projects/memoire/©franckchabin_TCCT_08.webp`} alt="Mémoire — détail 3" loading="lazy" />
    <img src={`${import.meta.env.BASE_URL}images/projects/memoire/©franckchabin_TCCT_09.webp`} alt="Mémoire — détail 4" loading="lazy" />
